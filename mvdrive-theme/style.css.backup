/*
 * This stylesheet intentionally does not include any CSS rules.  The user is
 * expected to supply their own stylesheets that rely on the HTML classes
 * defined in the various template files.  WordPress requires a style.css
 * file to register the theme, as noted in the WordPress theme development
 * documentation where it states that every theme must have at least a
 * style.css and an index.php file【708533204091608†L105-L112】.  The theme header
 * above satisfies that requirement without adding additional CSS.
 */

/*
 * Basic styling for the mvdrive theme.  These rules provide a neutral
 * appearance for the theme’s core components (header, navigation, movie
 * cards, pagination, notices, and single post layout).  You can extend or
 * override these rules as needed to match your own branding.  None of
 * these styles were copied from the reference site; they are provided as
 * a general starting point.
 */

body {
    font-family: "Open Sans", Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: #0e0e0e;
    color: #f5f5f5;
}

/* Header & Navigation */
.header {
    background-color: #101010;
    color: #ffffff;
    position: relative;
    z-index: 1000;
}
.header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
}
.hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    margin: 4px 0;
    background: #fff;
}
.logo img,
.logo .logo-image {
    max-height: 40px;
}
.nav-menu .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}
.nav-item {
    position: relative;
}
.nav-link {
    color: #e0e0e0;
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    display: flex;
    align-items: center;
    font-size: 0.9rem;
}
.nav-item:hover > .submenu,
.side-nav-item:hover > .side-submenu {
    display: block;
}
.submenu,
.side-submenu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #1c1c1c;
    list-style: none;
    padding: 0.5rem 0;
    min-width: 160px;
    z-index: 999;
}
.submenu li,
.side-submenu li {
    padding: 0;
}
.submenu a,
.side-submenu a {
    color: #e0e0e0;
    text-decoration: none;
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
}
.submenu a:hover,
.side-submenu a:hover {
    background: #333;
}

/* Search Bar */
.search-bar {
    position: relative;
    max-width: 200px;
}
.search-input {
    width: 100%;
    padding: 0.4rem 0.6rem;
    background: #1c1c1c;
    border: 1px solid #333;
    border-radius: 4px;
    color: #fff;
}
.search-icon {
    position: absolute;
    left: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    color: #777;
}

/* Mobile menu overlay and side menu */
.menu-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    z-index: 900;
}
.side-menu {
    position: fixed;
    left: -250px;
    top: 0;
    height: 100%;
    width: 250px;
    background: #101010;
    color: #fff;
    overflow-y: auto;
    transition: left 0.3s ease;
    z-index: 1000;
    padding-bottom: 2rem;
}
.side-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: #1c1c1c;
}
.side-nav-list,
.side-submenu {
    list-style: none;
    margin: 0;
    padding: 0;
}
.side-nav-link {
    display: block;
    color: #ddd;
    text-decoration: none;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
}

/* Notice Section */
.notice-section {
    background: #1c1c1c;
    color: #f5f5f5;
    padding: 1rem;
    margin: 1rem;
    border-radius: 4px;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.notice-icon svg {
    width: 24px;
    height: 24px;
}
.notice-close {
    background: none;
    border: none;
    color: #aaa;
    cursor: pointer;
    position: absolute;
    right: 0.5rem;
    top: 0.5rem;
}

/* Content Section & Grid */
.content-section {
    padding: 1rem;
}
.movies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
}
.poster-card {
    background: #1a1a1a;
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.2s ease;
}
.poster-card:hover {
    transform: translateY(-4px);
}
.poster-inner {
    position: relative;
}
.poster-image img {
    width: 100%;
    height: auto;
    display: block;
}
.poster-quality {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    padding: 0.2rem 0.4rem;
    font-size: 0.7rem;
    border-radius: 2px;
    text-transform: uppercase;
}
.poster-info {
    padding: 0.5rem;
}
.poster-title {
    font-size: 0.8rem;
    line-height: 1.2;
    color: #f5f5f5;
    margin: 0;
    height: 2.4em;
    overflow: hidden;
}

/* Pagination */
.pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem 0;
    gap: 0.25rem;
}
.page-btn {
    background: #1c1c1c;
    border: none;
    color: #fff;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}
.page-btn.disabled {
    opacity: 0.4;
    cursor: default;
}
.page-numbers {
    display: flex;
    gap: 0.25rem;
}
.page-num {
    color: #eee;
    padding: 0.4rem 0.6rem;
    text-decoration: none;
    font-size: 0.8rem;
}
.page-num.active {
    background: #333;
    border-radius: 3px;
}

/* Single Post Layout */
.app-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem;
}
.breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: #aaa;
    margin-bottom: 1rem;
    gap: 0.25rem;
}
.breadcrumb a {
    color: #64b5f6;
    text-decoration: none;
}
.breadcrumb-separator {
    color: #666;
}
.post-layout {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
}
.post-content {
    flex: 1 1 65%;
    background: #1a1a1a;
    padding: 1rem;
    border-radius: 4px;
}
.post-header .post-title {
    margin-top: 0;
    font-size: 1.5rem;
    color: #fff;
}
.post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #aaa;
    margin-bottom: 1rem;
}
.post-categories a {
    margin-right: 0.5rem;
    color: #64b5f6;
    text-decoration: none;
    font-size: 0.8rem;
    text-transform: uppercase;
}
.post-categories a:hover {
    text-decoration: underline;
}
.page-body {
    margin-bottom: 1rem;
    line-height: 1.6;
    color: #ddd;
}
.post-tags {
    margin: 1rem 0;
    font-size: 0.8rem;
}
.post-tags a {
    color: #64b5f6;
    text-decoration: none;
    margin-right: 0.5rem;
}
.post-tags a:hover {
    text-decoration: underline;
}

/* Telegram CTA */
.telegram-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #0088cc;
    padding: 1rem;
    border-radius: 4px;
    color: #fff;
    margin: 1rem 0;
}
.telegram-cta .telegram-icon {
    width: 40px;
    height: 40px;
    fill: #fff;
}
.telegram-title {
    font-weight: bold;
    font-size: 1.1rem;
}
.telegram-subtitle {
    font-size: 0.85rem;
    color: #f0f0f0;
}
.telegram-btn {
    background: #fff;
    color: #0088cc;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: bold;
}
.telegram-btn:hover {
    background: #f0f0f0;
}

/* Sidebar */
.post-sidebar {
    flex: 1 1 30%;
}
.sidebar-widget {
    background: #1a1a1a;
    padding: 0.75rem;
    border-radius: 4px;
    margin-bottom: 1rem;
}
.widget-title {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1rem;
    color: #fff;
}
.recent-posts,
.category-list {
    list-style: none;
    padding: 0;
    margin: 0;
}
.recent-post-item,
.category-list li {
    margin: 0.25rem 0;
}
.recent-post-item a,
.category-list a {
    color: #64b5f6;
    text-decoration: none;
    font-size: 0.85rem;
}
.recent-post-item a:hover,
.category-list a:hover {
    text-decoration: underline;
}

/* Footer */
.footer {
    background: #101010;
    color: #aaa;
}
.footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem;
    text-align: center;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .nav-menu,
    .search-bar {
        display: none;
    }
    .side-menu {
        width: 80%;
    }
    .post-layout {
        flex-direction: column;
    }
    .post-content,
    .post-sidebar {
        flex: 1 1 100%;
    }
    .movies-grid {
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    }
}